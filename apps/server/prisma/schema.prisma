datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// User — only the fields needed for the current MVP.
// Keeping the model minimal avoids premature abstraction
// and makes it easy to evolve as requirements solidify.
model User {
  id           String               @id @default(cuid())
  username     String               @unique
  passwordHash String?
  createdAt    DateTime             @default(now())
  members      ConversationMember[]
  messages     Message[]
}

// A join table links users to conversations. Storing participant
// IDs directly on Conversation would make it hard to query who
// belongs to what and would limit future features like roles or
// per-member settings. A dedicated model keeps things flexible.
model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

// Conversation — the core grouping for chat messages.
// Members and messages are separate models so each concept can
// evolve independently (e.g. roles for members, attachments for
// messages).
model Conversation {
  id            String               @id @default(cuid())
  lastMessage   String?
  lastMessageAt DateTime?
  createdAt     DateTime             @default(now())
  members       ConversationMember[]
  messages      Message[]
}

// A message belongs to a conversation rather than having a single
// receiver because conversations involve multiple participants.
// Querying by conversationId is the main access pattern (loading
// chat history), so the field is indexed for performance.
model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
}
